{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/computational-review/schemas/federated-claim-export-1.0.0.json",
  "title": "Federated provenance-bearing claim export",
  "type": "object",
  "additionalProperties": false,
  "required": ["@context", "@id", "@type", "schema:version", "dcterms:created", "prov:wasDerivedFrom", "source_native_provenance", "@graph"],
  "properties": {
    "@context": { "type": "object" },
    "@id": { "type": "string", "format": "uri" },
    "@type": { "const": "schema:Dataset" },
    "schema:version": { "type": "string" },
    "dcterms:created": { "type": "string", "format": "date-time" },
    "prov:wasDerivedFrom": { "type": "object" },
    "source_native_provenance": { "type": "object", "additionalProperties": false, "required": ["originating_repository", "rubric_version", "method_version", "semantic_origin", "oratlas_re_adjudicated", "assessment_unit", "disagreement", "export_semantics"], "properties": { "originating_repository": { "type": "string", "format": "uri", "pattern": "^https://" }, "rubric_version": { "type": "string", "minLength": 1 }, "method_version": { "type": "string", "minLength": 1 }, "semantic_origin": { "const": "source_native_trust" }, "oratlas_re_adjudicated": { "const": false }, "assessment_unit": { "type": "object" }, "disagreement": { "type": "object" }, "export_semantics": { "type": "object" } } },
    "@graph": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["@id", "@type", "np:hasAssertion", "np:hasProvenance", "np:hasPublicationInfo"],
        "properties": {
          "@id": { "type": "string", "format": "uri" },
          "@type": { "const": "np:Nanopublication" },
          "np:hasAssertion": { "$ref": "#/$defs/named_graph" },
          "np:hasProvenance": { "$ref": "#/$defs/named_graph" },
          "np:hasPublicationInfo": { "$ref": "#/$defs/named_graph" }
        }
      }
    }
  },
  "$defs": {
    "named_graph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["@id", "@graph"],
      "properties": {
        "@id": { "type": "string", "format": "uri" },
        "@graph": { "type": "array", "minItems": 1, "items": { "type": "object" } }
      }
    }
  }
}
