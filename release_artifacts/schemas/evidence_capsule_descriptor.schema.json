{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/computational-review/schemas/evidence-capsule-descriptor-1.0.0.json",
  "title": "Executable evidence capsule descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_native_provenance", "capsule_id", "release", "created_at", "status", "license", "execution", "artifacts"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "source_native_provenance": { "type": "object", "additionalProperties": false, "required": ["originating_repository", "rubric_version", "method_version", "semantic_origin", "oratlas_re_adjudicated", "assessment_unit", "disagreement", "export_semantics"], "properties": { "originating_repository": { "type": "string", "format": "uri", "pattern": "^https://" }, "rubric_version": { "type": "string", "minLength": 1 }, "method_version": { "type": "string", "minLength": 1 }, "semantic_origin": { "const": "source_native_trust" }, "oratlas_re_adjudicated": { "const": false }, "assessment_unit": { "type": "object" }, "disagreement": { "type": "object" }, "export_semantics": { "type": "object" } } },
    "capsule_id": { "type": "string", "pattern": "^capsule-[a-z0-9][a-z0-9-]{7,95}$" },
    "release": { "type": "object" },
    "created_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["passed", "failed", "blocked"] },
    "license": { "type": "string", "format": "uri" },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "started_at", "completed_at", "exit_code"],
      "properties": {
        "command": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "exit_code": { "type": "integer" }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "media_type", "expected_sha256"],
        "properties": {
          "path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9_.\\/-]+$" },
          "role": { "enum": ["code", "data", "environment", "output"] },
          "media_type": { "type": "string", "pattern": "^[A-Za-z0-9!#$&^_.+-]+/[A-Za-z0-9!#$&^_.+-]+$" },
          "expected_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      },
      "allOf": [
        { "contains": { "properties": { "role": { "const": "code" } }, "required": ["role"] } },
        { "contains": { "properties": { "role": { "const": "data" } }, "required": ["role"] } },
        { "contains": { "properties": { "role": { "const": "environment" } }, "required": ["role"] } },
        { "contains": { "properties": { "role": { "const": "output" } }, "required": ["role"] } }
      ]
    }
  }
}
